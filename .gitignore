# NovaOS — .gitignore
# Aggiornato Sprint 5 — Development Infrastructure

# --- Sistema operativo / IDE ---
.DS_Store
Thumbs.db
Desktop.ini
*.swp
*.swo
*~
.idea/
.vscode/
*.code-workspace
.cursor/

# --- Ambienti e segreti ---
.env
.env.*
!.env.example
configs/bootstrap/env.sh
*.pem
*.key
*.p12
*.pfx
secrets/
credentials/
*.credentials.json
service-account*.json

# --- Dipendenze e tool ---
node_modules/
.npm/
.pnpm-store/
.yarn/
.yarn/cache
.venv/
venv/
__pycache__/
*.py[cod]
*$py.class
.Python
*.egg-info/
.eggs/
dist/
.cache/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/
coverage/
htmlcov/
.coverage
.coverage.*

# --- Build workspace (Sprint 5): ignora contenuti, non la struttura ---
build/cache/**
!build/cache/README.md
!build/cache/.gitkeep
build/work/**
!build/work/README.md
!build/work/.gitkeep
build/logs/**
!build/logs/README.md
!build/logs/.gitkeep

# --- Output ISO / immagini ---
iso/releases/**
!iso/releases/README.md
iso/latest/**
!iso/latest/README.md
*.iso
*.img
*.raw
*.qcow2
*.vmdk
*.vdi
*.squashfs
*.rootfs
*.tar
*.tar.gz
*.tar.xz
*.deb
*.rpm
*.pkg.tar*
*.apk
*.flatpak
*.snap
out/
output/
artifacts/
overlay/
chroot/
sysroot/
tmp-build/
.build/

# --- Log e temporanei ---
*.log
tmp/
temp/
*.tmp
*.bak
*.orig
*.rej

# --- Test / locali ---
*.local
local/
.scratch/
vm/disks/**
!vm/disks/README.md
